    "theme:hash": "node -e \"const c=require('crypto');const m=require('fs').readFileSync('src/lib/theme.ts','utf8');const s=m.match(/\\\"(try{[^\\\"]*)\\\"/)[1];console.log(\\\"'sha256-\\\"+c.createHash('sha256').update(s,'utf8').digest('base64')+\\\"'\\\")\""
  },
