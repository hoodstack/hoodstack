    "@hoodstack/config": "workspace:*",
    "@hoodstack/design-tokens": "workspace:*",
    "@hoodstack/errors": "workspace:*",
    "@hoodstack/network": "workspace:*",
    "next": "^15.1.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@hoodstack/tsconfig": "workspace:*",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
