# HoodStack environment configuration
#
# Copy to `.env` and fill in. `.env` is gitignored.
#
# PLACEHOLDERS ONLY IN THIS FILE. Never commit a real value here, including a
# "temporary" or "test" one - test credentials get promoted to production, and
# this file is public.
#
# Rule: any variable prefixed NEXT_PUBLIC_ is embedded in the browser bundle and
# is readable by anyone. A server secret must never be given that prefix.

# ── core services ────────────────────────────────────────────────────────────
DATABASE_URL=
REDIS_URL=

# ── application secrets ──────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=
# Encrypts provider credentials at rest. Rotating this requires re-encrypting
# stored secrets; see docs/security/key-management.md.
ENCRYPTION_KEY=

# ── public URLs ──────────────────────────────────────────────────────────────
HOODSTACK_PUBLIC_URL=http://localhost:3000
HOODSTACK_API_URL=http://localhost:3001

# ── Robinhood Chain RPC ──────────────────────────────────────────────────────
# Leave blank in development to fall back to the shared public endpoints.
# In production these are REQUIRED: the platform refuses to start rather than
# silently depend on a rate-limited shared endpoint.
ROBINHOOD_TESTNET_RPC_URL=
ROBINHOOD_MAINNET_RPC_URL=
ROBINHOOD_TESTNET_WS_URL=
ROBINHOOD_MAINNET_WS_URL=

# ── account abstraction provider ─────────────────────────────────────────────
# HoodStack does not operate a bundler. This configures a third-party provider
# behind the adapter in @hoodstack/accounts.
AA_PROVIDER=
AA_PROVIDER_API_KEY=

# ── paymaster / gas sponsorship provider ─────────────────────────────────────
# HoodStack does not operate paymaster liquidity.
PAYMASTER_PROVIDER=
PAYMASTER_API_KEY=

# ── indexed chain data provider ──────────────────────────────────────────────
# HoodStack does not operate a proprietary indexer.
INDEXER_PROVIDER=
INDEXER_PROVIDER_API_KEY=

# ── email ────────────────────────────────────────────────────────────────────
EMAIL_PROVIDER=
EMAIL_API_KEY=

# ── observability ────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=
SENTRY_DSN=

# ── mainnet safety ───────────────────────────────────────────────────────────
# Mainnet writes are disabled by default. Enabling this is not sufficient on its
# own - a project must also opt in explicitly through its own settings.
HOODSTACK_ALLOW_MAINNET_WRITES=false

# ── browser-exposed configuration ────────────────────────────────────────────
# Public by definition. Nothing secret may appear below this line.
NEXT_PUBLIC_DEFAULT_CHAIN_ID=46630
NEXT_PUBLIC_HOODSTACK_APP_URL=http://localhost:3000/app
NEXT_PUBLIC_HOODSTACK_PROJECT_ID=
