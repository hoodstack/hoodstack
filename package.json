{
  "name": "hoodstack",
  "version": "0.0.0",
  "private": true,
  "description": "Developer infrastructure for Robinhood Chain.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/hoodstack/hoodstack.git"
  },
  "homepage": "https://www.hoodstack.io",
  "packageManager": "pnpm@10.34.4",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=10"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "typecheck": "turbo run typecheck",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yaml,yml,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yaml,yml,css}\"",
    "clean": "turbo run clean && rimraf node_modules",
    "lint:fix": "eslint . --fix"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "@hoodstack/eslint-config": "workspace:*",
    "eslint": "^9.17.0"
  }
}
